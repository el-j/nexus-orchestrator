# Binaries & build output
/nexus-orchestrator
/nexus-cli
/nexus-daemon
# Unified build output — all artifacts go under build/
# Preserve build/darwin/ and build/windows/ (Wails build resources, tracked in git)
build/bin/
build/native/
build/linux_amd64/
build/linux_arm64/
build/darwin_amd64/
build/darwin_arm64/
build/windows_amd64/
build/desktop/
build/vscode/
build/docs/
build/frontend/*
!build/frontend/.gitkeep
*.exe

# SQLite databases
*.db
*.db-journal
*.db-shm
*.db-wal

# Go module cache / vendor
vendor/

# OS files
.DS_Store
Thumbs.db

# Root dev tooling (husky, lint-staged, prettier — installed at repo root)
node_modules/
package-lock.json

# Frontend build cache
frontend/node_modules/
frontend/.vite/
frontend/src/wailsjs/
coverage.out

# Docs / Action / VSCode extension intermediate build artifacts
docs/dist/
docs/node_modules/
github-action/node_modules/
github-action/coverage/
vscode-extension/dist/

coverage

# air hot-reload build output
tmp/
