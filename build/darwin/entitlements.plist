<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Hardened Runtime: allow dylibs loaded at runtime (required for Wails WebKit) -->
  <key>com.apple.security.cs.allow-jit</key>
  <false/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <false/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Network access: daemon speaks HTTP on :9998/:9999 and connects to local LLM providers -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- File access: read/write project files selected by the user -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <!-- Downloads: write LLM-generated files to the downloads directory -->
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>
</dict>
</plist>
